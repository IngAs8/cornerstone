# ─── Database ───────────────────────────────────────────────────────────────
# Get from Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

# ─── Supabase (web client) ──────────────────────────────────────────────────
# Get from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # server-only, NEVER expose to client

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Use test keys until ready for production
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe price IDs (one per plan, for both monthly and yearly)
STRIPE_PRICE_PERSONAL_MONTHLY="price_..."
STRIPE_PRICE_PERSONAL_YEARLY="price_..."
STRIPE_PRICE_FAMILY_S_MONTHLY="price_..."
STRIPE_PRICE_FAMILY_S_YEARLY="price_..."
STRIPE_PRICE_FAMILY_M_MONTHLY="price_..."
STRIPE_PRICE_FAMILY_M_YEARLY="price_..."

# ─── Anthropic (Claude) ─────────────────────────────────────────────────────
# Used for: AI Financial Advisor (Sonnet 4.6) + WhatsApp parser (Haiku)
ANTHROPIC_API_KEY="sk-ant-..."

# ─── WhatsApp (Meta Cloud API) ──────────────────────────────────────────────
# Get from Meta Business → WhatsApp → API Setup
WHATSAPP_VERIFY_TOKEN="any-random-string-you-choose"
WHATSAPP_API_TOKEN="EAAxxx..."
WHATSAPP_PHONE_NUMBER_ID="123456789"
WHATSAPP_BUSINESS_ACCOUNT_ID="123456789"

# ─── Exchange Rates ─────────────────────────────────────────────────────────
# openexchangerates.org — free tier: 1000 req/month
OPEN_EXCHANGE_RATES_APP_ID="..."

# ─── Asset Prices ───────────────────────────────────────────────────────────
# CoinGecko (crypto) — free tier no key needed; pro key optional
COINGECKO_API_KEY=""

# Financial Modeling Prep (stocks/ETFs) — free tier: 250 req/day
FMP_API_KEY="..."

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@cornerstone.app"

# ─── Cron Security ──────────────────────────────────────────────────────────
# Random secret to protect cron endpoints (exchange rate sync, price updates)
CRON_SECRET="generate-with-openssl-rand-hex-32"

# ─── App Config ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Cornerstone Capital"
